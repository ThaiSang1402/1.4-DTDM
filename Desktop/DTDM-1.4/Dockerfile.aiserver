# Dockerfile for AI Server on Render
FROM python:3.11-slim

WORKDIR /app

# Copy requirements and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Set environment
ENV PYTHONPATH=/app
ENV PORT=8080

# Expose port
EXPOSE $PORT

# Start AI Server
CMD uvicorn scalable_ai_api.ai_server.render_app:app --host 0.0.0.0 --port $PORT